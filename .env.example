# SecurityCouncil Audit Pipeline — LLM Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# --- API Keys ---
# Add only the key(s) for the provider(s) you are using.
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# --- Per-auditor model selection ---
# Each auditor and the aggregator can be routed to a different model independently.
#
# LiteLLM model string examples:
#   Anthropic (current default): claude-sonnet-4-6
#   Local Ollama:                ollama/qwen2.5:72b
#   OpenAI:                      gpt-4o
#
# See full provider list: https://docs.litellm.ai/docs/providers

AUDIT_MODEL_CONFIGURATION=claude-sonnet-4-6
AUDIT_MODEL_DEPENDENCY=claude-sonnet-4-6
AUDIT_MODEL_COST_USAGE=claude-sonnet-4-6
AUDIT_MODEL_EXPOSURE=claude-sonnet-4-6
AUDIT_MODEL_AGGREGATOR=claude-sonnet-4-6
